# Public URL reachable from Twilio (use ngrok for local dev)
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+14155551234

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# ElevenLabs (optional, for handoff MP3)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional override. If omitted, app defaults to bundled model path:
# backend/app/models/vosk/vosk-model-small-en-us-0.15
VOSK_MODEL_PATH=
